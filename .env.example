OPENAI_API_KEY=your-openai-api-key-here
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# 카카오 로그인 (백엔드에 POST /api/auth/kakao/callback, /register 있음)
# REST API 키 없이 사용: 백엔드가 GET /api/auth/kakao 를 제공하면 .env 설정 없이 동작
# 백엔드 시작 URL이 다르면 여기 지정 (예: /api/auth/kakao/authorize)
# VITE_KAKAO_AUTH_URL=/api/auth/kakao
# 프론트에서 직접 카카오 인증 페이지로 보내려면 REST API 키 설정 (선택)
# VITE_KAKAO_CLIENT_ID=your-kakao-rest-api-key
# VITE_KAKAO_REDIRECT_URI=http://localhost:4173/auth

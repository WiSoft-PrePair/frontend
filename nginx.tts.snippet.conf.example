# prepair.wisoft.dev server { ... } 참고용
#
# 팀 포트 예시:
#   FE(vite preview / PM2 fe)     → 7000
#   API-Gateway                     → 7100
#   BE-Nest                         → 7200
#   BE-Java                         → 7300
#   TTS(PM2 tts, scripts/tts-proxy) → 7400  (ecosystem TTS_PORT 와 동일하게)
#
# ★ /api/tts 는 반드시 Gateway(7100)용 location /api/ 보다 위에 둡니다.

location /tts {
  proxy_pass http://127.0.0.1:7400;
  proxy_http_version 1.1;
  proxy_set_header Host $host;
  proxy_set_header X-Real-IP $remote_addr;
  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  proxy_set_header X-Forwarded-Proto $scheme;
}

location ^~ /api/tts {
  proxy_pass http://127.0.0.1:7400;
  proxy_http_version 1.1;
  proxy_set_header Host $host;
  proxy_set_header X-Real-IP $remote_addr;
  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  proxy_set_header X-Forwarded-Proto $scheme;
}

# (참고) 나머지 API는 Gateway 예시 — 실제 파일 순서·경로는 환경에 맞게
# location /api/ {
#   proxy_pass http://127.0.0.1:7100;
#   ...
# }
